# --- LLM provider selection ---
# One of: fireworks | openai_compatible | anthropic | fake
CODEVERSE_LLM_PROVIDER=fake

# Fireworks AI (primary target per product spec). Gemma 4 exists on Fireworks
# but has NO serverless tier — it requires an on-demand GPU deployment
# (~$40/hr), so it's not used by default. Using a serverless chat model
# instead (no deployment step, pay-per-token). Swap the model id below for
# any other serverless model already enabled on your account:
#   accounts/fireworks/models/gpt-oss-120b     (default, 131K ctx, tool calling)
#   accounts/fireworks/models/glm-5p1          (202K ctx, tool calling)
#   accounts/fireworks/models/glm-5p2          (1M ctx, tool calling)
#   accounts/fireworks/models/deepseek-v4-pro  (1M ctx, tool calling)
#   accounts/fireworks/models/kimi-k2p6        (262K ctx, vision + tools)
CODEVERSE_FIREWORKS_API_KEY=
CODEVERSE_FIREWORKS_MODEL=accounts/fireworks/models/gpt-oss-120b

# Generic OpenAI-compatible endpoint (works for OpenAI, Fireworks, vLLM, ...)
CODEVERSE_OPENAI_BASE_URL=https://api.openai.com/v1
CODEVERSE_OPENAI_API_KEY=
CODEVERSE_OPENAI_MODEL=gpt-4o-mini

# Anthropic
CODEVERSE_ANTHROPIC_API_KEY=
CODEVERSE_ANTHROPIC_MODEL=claude-sonnet-5

# --- Database ---
CODEVERSE_DATABASE_URL=postgresql+psycopg://codeverse:codeverse@localhost:5432/codeverse

# --- Auth ---
CODEVERSE_JWT_SECRET=change-me-in-production
CODEVERSE_JWT_EXPIRE_MINUTES=1440

# --- Sandbox ---
CODEVERSE_SANDBOX_TIMEOUT_SECONDS=10
CODEVERSE_SANDBOX_MEMORY_LIMIT=256m
CODEVERSE_SANDBOX_CPU_LIMIT=1.0
CODEVERSE_SANDBOX_PIDS_LIMIT=64
